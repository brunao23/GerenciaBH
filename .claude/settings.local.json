{
  "model": "claude-sonnet-4-6",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "fastMode": true,
  "autoCompactWindow": 100000,
  "includeGitInstructions": false,
  "promptSuggestionEnabled": false,
  "outputStyle": "concise",
  "language": "pt-br",
  "skillListingMaxDescChars": 256,
  "skillListingBudgetFraction": 0.003,
  "skillOverrides": {
    "fullstack": "on",
    "megaskill": "on",
    "cybersecurity": "name-only",
    "simplify": "on",
    "update-config": "name-only",
    "init": "off",
    "insights": "off",
    "team-onboarding": "off",
    "statusline": "off",
    "review": "off",
    "loop": "off",
    "schedule": "off",
    "claude-api": "off",
    "keybindings-help": "off",
    "security-review": "off"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebSearch",
      "WebFetch(*)",
      "Agent(*)",
      "Skill(*)"
    ]
  }
}
