# Variáveis de Ambiente para Vercel

# JWT Secret (gere um novo em produção)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# Admin Password
ADMIN_PASSWORD=admin@corelion2024

# Supabase (já configurado)
# NEXT_PUBLIC_SUPABASE_URL=...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...  # obrigatório no servidor para evitar bloqueio por RLS

# Meta Cloud API (WhatsApp Oficial)
# NEXT_PUBLIC_META_APP_ID=...
# NEXT_PUBLIC_META_CONFIG_ID=...          # Embedded Signup Config ID
# NEXT_PUBLIC_META_SOLUTION_ID=...        # Opcional, se usar Solutions (Onboarding guiado)
# META_APP_SECRET=...                     # App Secret (server only)
# META_API_VERSION=v21.0
# META_WEBHOOK_VERIFY_TOKEN=...           # Opcional: token fixo para validar webhook
