# Exemplo de .env
CLAUDE_API_KEY=sua_chave_aqui

# Discord operational alerts
DISCORD_SYSTEM_LOG_WEBHOOK_URL=
DISCORD_SYSTEM_LOG_ENABLED=true
DISCORD_SYSTEM_LOG_LEVELS=warning,error,critical,urgent,attention
DISCORD_SYSTEM_LOG_DEDUPE_SECONDS=30

# Copie este arquivo para `.env` e substitua pela sua chave real.
