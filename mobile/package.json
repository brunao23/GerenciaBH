{
  "name": "gerenciabh-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:android:preview": "npx eas-cli build --platform android --profile preview --non-interactive",
    "build:android:production": "npx eas-cli build --platform android --profile production --non-interactive",
    "build:ios:production": "npx eas-cli build --platform ios --profile production --non-interactive",
    "build:all:production": "npx eas-cli build --platform all --profile production --non-interactive"
  },
  "dependencies": {
    "@react-native-community/netinfo": "11.4.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
